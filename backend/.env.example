# JanaNaadi Backend Environment Variables

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# LLM Configuration — choose ONE:
# Option 1: Cloud APIs (Bytez + Gemini)
BYTEZ_API_KEY=your-bytez-api-key
BYTEZ_MODEL=google/gemini-2.5-flash
GEMINI_API_KEY=your-gemini-api-key

# Option 2: Local LLM (Ollama) — set to true to use Ollama instead of cloud
USE_LOCAL_LLM=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5

# Optional — data source credentials
TWITTER_BEARER_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# App settings
DEBUG=true
